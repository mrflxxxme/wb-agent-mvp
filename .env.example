# =============================================================
# WB AI-Agent MVP — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# =============================================================

# ── Google Sheets ──────────────────────────────────────────
SPREADSHEET_ID=1DjfLItDaSZRJNMKId5mC_fJMpvDSPkcWeHD_Sy7RmTE
# Base64-encoded service account JSON key
# Generate: base64 -w 0 your-key.json  (Linux/Mac)
#           certutil -encode your-key.json key_b64.txt  (Windows)
GOOGLE_CREDENTIALS_JSON=<base64-encoded-service-account-json>

# ── Gemini AI ──────────────────────────────────────────────
GEMINI_API_KEY=<your-google-ai-studio-key>
GEMINI_MODEL=gemini-2.0-flash

# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<your-bot-token-from-botfather>
# Comma-separated numeric user IDs (get from @userinfobot)
TELEGRAM_ALLOWED_IDS=233085299
# Numeric ID of the owner chat for system error notifications
OWNER_CHAT_ID=233085299

# ── Schedule (UTC) ─────────────────────────────────────────
# 06:00 UTC = 09:00 MSK
DAILY_REPORT_HOUR_UTC=6
WEEKLY_REPORT_HOUR_UTC=6
WEEKLY_REPORT_WEEKDAY=0    # 0=Monday

# ── Storage ────────────────────────────────────────────────
CACHE_TTL_MINUTES=5
DATA_DIR=/app/data         # Override for local dev: ./data

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
